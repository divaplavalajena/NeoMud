{
  "mcpServers": {
    "nano-banana": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@aeven/nanobanana-mcp@latest"
      ],
      "env": {
        "MODEL_API_KEY": "${NANO_BANANA_API_KEY}",
        "MODEL_ID": "google/gemini-3.1-flash-image-preview"
      }
    },
    "gemini-imagen": {
      "command": "npx",
      "args": [
        "-y",
        "gemini-imagen-mcp-server"
      ],
      "env": {
        "GEMINI_API_KEY": "${GEMINI_API_KEY}"
      }
    },
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest", "--caps", "vision"]
    },
    "elevenlabs-sfx": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "elevenlabs-mcp"
      ],
      "env": {
        "ELEVENLABS_API_KEY": "${ELEVENLABS_API_KEY}",
        "ELEVENLABS_MCP_BASE_PATH": "maker/default_world_src/assets"
      }
    }
  }
}
